[
  {
    "name": "Acute Myocardial Infarction",
    "icd10": "I21",
    "system": "cardiovascular",
    "acuity": "acute",
    "prevalence": "common",
    "description": "Heart attack caused by blocked coronary artery leading to myocardial necrosis",
    "symptoms": {
      "primary": [
        "chest_pain",
        "dyspnea"
      ],
      "secondary": [
        "diaphoresis",
        "nausea",
        "fatigue",
        "palpitations",
        "anxiety",
        "arm_pain",
        "jaw_pain"
      ],
      "atypical": [
        "epigastric_pain",
        "isolated_dyspnea",
        "syncope"
      ]
    },
    "vital_sign_patterns": {
      "heart_rate": ">100 or bradycardia",
      "blood_pressure": ">=140/90 or low if shock",
      "oxygen_saturation": "<95 if heart failure",
      "temperature": "Normal or mild elevation"
    },
    "lab_tests": [
      "Troponin I/T",
      "CK-MB",
      "ECG (ST elevation)",
      "BNP",
      "Lipid Profile"
    ],
    "key_diagnostic_questions": [
      "Is the chest pain crushing, squeezing, or pressure-like?",
      "Does the pain radiate to your left arm, jaw, neck, or back?",
      "Did the pain come on suddenly, especially during exertion or stress?",
      "Are you sweating profusely with the chest pain?",
      "Does rest or nitroglycerin relieve the pain?",
      "Do you have a history of smoking, diabetes, or high blood pressure?",
      "Is there a family history of heart disease before age 55?"
    ],
    "risk_factors": [
      "smoking",
      "hypertension",
      "diabetes",
      "hyperlipidemia",
      "family_history_cad",
      "obesity",
      "age_over_45"
    ],
    "red_flags": [
      "Pain lasting >20 minutes unrelieved by rest",
      "Crushing pressure with diaphoresis",
      "Syncope with chest pain"
    ],
    "severity_class": "critical",
    "differentiating_features": [
      "Crushing/squeezing chest pressure (not sharp or burning)",
      "Radiation to left arm, jaw, or back",
      "Diaphoresis (profuse sweating) with chest pain",
      "Pain NOT relieved by antacids or position change",
      "Associated with exertion or stress onset",
      "Risk factors: smoking, diabetes, hypertension, family history"
    ]
  },
